{
  "name": "@marlinjai/brain-core",
  "version": "0.1.0",
  "description": "Shared infrastructure for Brain services (auth, crypto, errors, types)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sdk": {
      "import": {
        "types": "./dist/sdk/index.d.ts",
        "default": "./dist/sdk/index.js"
      },
      "require": {
        "types": "./dist/sdk/index.d.cts",
        "default": "./dist/sdk/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "docs:dev": "clearify dev",
    "docs:build": "clearify build"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.4"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@marlinjai/clearify": "^1.9.0",
    "@cloudflare/workers-types": "^4.20240117.0",
    "hono": "^4.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "keywords": [
    "brain",
    "core",
    "auth",
    "crypto",
    "cloudflare",
    "workers",
    "shared"
  ],
  "author": "marlinjai",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0"
}
